{
  "name": "@oppiai/native",
  "version": "0.2.11",
  "type": "module",
  "description": "Rust-first OPPi preview launcher with bundled oppi-shell and oppi-server binaries.",
  "license": "MIT",
  "keywords": [
    "oppi",
    "native",
    "rust",
    "coding-agent",
    "agent-cli",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RemindZ/oppi.git",
    "directory": "packages/native"
  },
  "bugs": {
    "url": "https://github.com/RemindZ/oppi/issues"
  },
  "homepage": "https://github.com/RemindZ/oppi#readme",
  "engines": {
    "node": ">=20.6.0"
  },
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "oppi-native": "./dist/main.js",
    "oppi-rs": "./dist/main.js"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc && node -e \"try{require('fs').chmodSync('dist/main.js',0o755)}catch{}\"",
    "build:binaries": "node scripts/build-binaries.mjs",
    "test": "pnpm run build && node --test dist/main.test.js",
    "prepack": "pnpm run build && pnpm run build:binaries"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
